{
    "name": "ldiebold/isolate",
    "description": "Isolate one Laravel checkout's runtime footprint (ports, prefixes, database name) from sibling checkouts of the same app.",
    "version": "0.0.2",
    "keywords": ["laravel", "isolation", "ports", "worktree", "dev-environment"],
    "license": "MIT",
    "support": {
        "issues": "https://github.com/ldiebold/isolate/issues",
        "source": "https://github.com/ldiebold/isolate"
    },
    "authors": [
        {
            "name": "Lukas Diebold"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "symfony/process": "^7.0 || ^8.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^4.0",
        "pestphp/pest-plugin-laravel": "^3.0 || ^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ldiebold\\Isolate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ldiebold\\Isolate\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "@php vendor/bin/pest",
        "test-coverage": "@php vendor/bin/pest --coverage",
        "lint": [
            "@php vendor/bin/pint --ansi",
            "@php vendor/bin/phpstan analyse --verbose --ansi"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ldiebold\\Isolate\\IsolateServiceProvider"
            ],
            "aliases": {
                "Isolate": "Ldiebold\\Isolate\\Facades\\Isolate"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
