includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    level: 6
    paths:
        - src
    tmpDir: build/phpstan
    # Container bindings (e.g. make('redis')) are resolved to concrete types by
    # larastan, but the package must still guard them at runtime for apps where
    # the binding is absent, so PHPDoc types are not treated as certain.
    treatPhpDocTypesAsCertain: false
